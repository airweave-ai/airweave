{
  "name": "airweave-mcp-search",
  "version": "0.5.7",
  "mcpName": "io.github.airweave-ai/search",
  "description": "MCP server for searching Airweave collections",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "airweave-mcp-search": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "start:http": "node build/index-http.js",
    "dev": "npm run build && npm run start",
    "dev:http": "npm run build && npm run start:http",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mcp": "vitest run tests/mcp-server.test.ts",
    "test:http": "vitest run tests/http-transport.test.ts",
    "test:oauth": "vitest run tests/auth/ tests/api/org-resolver.test.ts tests/index-http-oauth.test.ts",
    "test:all": "npm run test:mcp && npm run test:http && npm run test:oauth",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "airweave",
    "search",
    "model-context-protocol",
    "ai",
    "vector-search",
    "claude",
    "cursor"
  ],
  "author": "Airweave",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/airweave-ai/airweave.git",
    "directory": "mcp"
  },
  "homepage": "https://airweave.ai",
  "bugs": {
    "url": "https://github.com/airweave-ai/airweave/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@airweave/sdk": "^0.9.44",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.2.1",
    "ioredis": "^5.8.1",
    "jose": "^6.1.0",
    "posthog-node": "^5.24.11",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "build",
    "README.md"
  ]
}

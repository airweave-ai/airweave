meta {
  name: 2. Create HERB Messaging Source
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/source-connections/
  body: json
  auth: none
}

body:json {
  {
    "name": "HERB Messaging",
    "short_name": "herb_messaging",
    "readable_collection_id": "{{readableCollectionId}}",
    "authentication": {
      "credentials": {
        "placeholder": "herb"
      }
    },
    "config": {
      "data_dir": "/Users/laurensvm/Downloads/HERB-main/data"
    },
    "sync_immediately": true
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    bru.setVar("messagingSourceConnectionId", res.body.id);
  }
}

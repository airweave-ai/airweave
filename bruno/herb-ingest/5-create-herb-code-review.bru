meta {
  name: 5. Create HERB Code Review Source
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/source-connections/
  body: json
  auth: none
}

body:json {
  {
    "name": "HERB Code Review",
    "short_name": "herb_code_review",
    "readable_collection_id": "{{readableCollectionId}}",
    "authentication": {
      "credentials": {
        "placeholder": "herb"
      }
    },
    "config": {
      "data_dir": "/Users/laurensvm/Downloads/HERB-main/data"
    },
    "sync_immediately": true
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    bru.setVar("codeReviewSourceConnectionId", res.body.id);
  }
}

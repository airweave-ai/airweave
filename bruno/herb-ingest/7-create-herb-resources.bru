meta {
  name: 7. Create HERB Resources Source
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/source-connections/
  body: json
  auth: none
}

body:json {
  {
    "name": "HERB Resources",
    "short_name": "herb_resources",
    "readable_collection_id": "{{readableCollectionId}}",
    "authentication": {
      "credentials": {
        "placeholder": "herb"
      }
    },
    "config": {
      "data_dir": "/Users/laurensvm/Downloads/HERB-main/data"
    },
    "sync_immediately": true
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    bru.setVar("resourcesSourceConnectionId", res.body.id);
  }
}

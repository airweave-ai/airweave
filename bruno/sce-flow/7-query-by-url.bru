meta {
  name: 7. Query entities by URL annotation
  type: http
  seq: 7
}

get {
  url: http://localhost:8081/search/?yql=select entity_id, airweave_system_metadata_entity_type, airweave_system_metadata_annotations from sources * where airweave_system_metadata_annotations contains 'url:http://localhost:8001/health' and !(airweave_system_metadata_entity_type matches '.*CodeFileEntity.*')&hits=10
  auth: none
}

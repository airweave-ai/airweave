meta {
  name: 8. Query entities by email annotation
  type: http
  seq: 8
}

get {
  url: http://localhost:8081/search/?yql=select entity_id, airweave_system_metadata_entity_type, airweave_system_metadata_annotations from sources * where airweave_system_metadata_annotations matches 'email:.*' and !(airweave_system_metadata_entity_type matches '.*CodeFileEntity.*')&hits=10
  auth: none
}

meta {
  name: 4. Run Sync (manual trigger)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/source-connections/{{sourceConnectionId}}/run
  body: json
  auth: none
}

body:json {
  {
    "force_full_sync": false
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    bru.setVar("syncJobId", res.body.id);
  }
}

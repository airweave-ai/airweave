meta {
  name: 3. List Sync Jobs
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/source-connections/{{sourceConnectionId}}/jobs
  auth: none
}

script:post-response {
  if (res.status === 200 && res.body.length > 0) {
    var latest = res.body[0];
    bru.setVar("syncJobId", latest.id);
    bru.setVar("syncId", latest.sync_id);
  }
}

meta {
  name: 1. Create Collection
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/collections/
  body: json
  auth: none
}

body:json {
  {
    "name": "Airweave Repo"
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    bru.setVar("collectionId", res.body.id);
    bru.setVar("readableCollectionId", res.body.readable_id);
  }
}
